# Vercel Environment Variables - Nike Vibe Recruitment Engine

# Turso DB Integration
TURSO_DATABASE_URL="libsql://your-turso-database-url"
TURSO_AUTH_TOKEN="your-turso-auth-token"

# LexGuard Crypto System 
# Note: Kunci harus berjumlah tepat 32 karakter (256-bit) untuk enkripsi algoritma AES-256-CBC
LEXGUARD_SECRET_KEY="12345678901234567890123456789012"

# Ollama Data Ingestion / n8n Webhook Endpoint
N8N_WEBHOOK_URL="https://your-n8n-instance.com/webhook/nike-5g-ingest"
OLLAMA_ENDPOINT="http://localhost:11434/api/generate"
